# local-auto configuration
daemon:
  port: 3847
  host: 127.0.0.1
  maxConcurrentWorkers: 2

ai:
  provider: anthropic      # "anthropic" or "gemini"
  model: claude-sonnet-4-6 # provider-specific model name
  maxIterations: 20        # max AI action loop iterations per task

# Sites to automate
sites:
  - name: example-site
    url: https://example.com/dashboard
    login:
      type: form
      usernameField: "#username"
      passwordField: "#password"
      submitButton: "submit"
      credentials:
        username: ${DASHBOARD_USER}
        password: ${DASHBOARD_PASS}
    tasks:
      - name: pull-data
        schedule: "5 0,9,15,21 * * *"
        prompt: "extract the relevant data from the dashboard"
        output:
          webhooks: true
        retry:
          maxAttempts: 3
          backoffMs: 5000

notifications:
  telegram:
    botToken: ${TELEGRAM_BOT_TOKEN}
    chatId: ${TELEGRAM_CHAT_ID}
